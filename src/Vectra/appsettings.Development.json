{
  "System": {
    "Server": {
      "Http": {
        "Port": 7080
      }
    },
    "Storage": {
      "Database": {
        "DefaultProvider": "Sqlite",
        "Providers": {
          "Postgres": {
            "ConnectionString": "Host=localhost;Database=mydb;Username=user;Password=pass"
          },
          "Sqlite": {
            "ConnectionString": "Data Source=vectra.db"
          }
        }
      },
      "Cache": {
        "DefaultProvider": "Memory",
        "Providers": {
          "Redis": {
            "Address": "localhost:6379",
            "TimeToLive": "1.00:00:00",
            "AbortOnConnectFail": false,
            "ConnectRetry": 5,
            "ConnectTimeout": "00:00:05"
          },
          "Memory": {
            "TimeToLive": "1.00:00:00"
          }
        }
      }
    }
  },
  "Observability": {
    "Logging": {
      "File": {
        "Enabled": true,
        "LogPath": "logs/log-.txt",
        "RollingInterval": "Day",
        "MinimumLevel": "Warning"
      },
      "Seq": {
        "Enabled": false,
        "ServerUrl": "http://localhost:5341",
        "MinimumLevel": "Information"
      }
    }
  },
  "Security": {
    "AgentAuth": {
      "Provider": "SelfSigned",
      "SelfSigned": {
        "Secret": "v3ctra-dev-9F2kLmQ7xP1zRt8Nw4By6Hs0Jd5Ua3",
        "Issuer": "vectra",
        "Audience": "vectra-agents",
        "Expiration": "00:15:00"
      }
    }
  },
  "Semantic": {
    "Enabled": true,
    "ConfidenceThreshold": 0.7,
    "DefaultProvider": "local",
    "Providers": {
      "Local": {
        "ModelPath": "models/local.onnx"
      },
      "Ollama": {
        "Url": "http://localhost:11434",
        "ModelName": "llama3.2"
      },
      "AzureOpenAI": {
        "Endpoint": "https://your-resource.openai.azure.com/",
        "Key": "your-api-key",
        "ModelName": "gpt-4o"
      },
      "Gemini": {
        "ProjectId": "your-project",
        "Location": "us-central1",
        "ModelName": "gemini-1.5-flash"
      }
    }
  },
  "HumanInTheLoop": {
    "Enabled": true,
    "Threshold": 0.8
  },
  "Policy": {
    "Enabled": true,
    "DefaultProvider": "Internal",
    "Providers": {
      "Internal": {
        "Directory": "D:/vectra_policies/"
      },
      "Opa": {
        "BaseUrl": "http://localhost:8181",
        "Path": "/v1/data/vectra/authz",
        "Timeout": "00:00:05"
      }
    }
  }
}